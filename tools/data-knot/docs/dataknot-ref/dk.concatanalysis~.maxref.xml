<?xml version='1.0' encoding='utf-8' standalone='yes'?>
<?xml-stylesheet href="./_c74_ref.xsl" type="text/xsl"?>

<c74object name='dk.concatanalysis~' category='' module='dataknot'>
    <digest>Descriptor analysis for real-time mosaicing
</digest>
    <description>The <o>dk.concatanalysis~</o> object is based on <o>dk.descriptorsrt~</o> but has all of the appropriate settings pre-baked so it can get sent directly to <o>dk.concatmatch.</o> It also takes some playback controls via <at>rate</at> and <at>random</at> messages.
</description>
    <discussion>If you want to learn more about the underlying algorithms have a look at these articles:<br/><a href="https://learn.flucoma.org/reference/loudness">https://learn.flucoma.org/reference/loudness</a><br/><a href="https://learn.flucoma.org/reference/spectralshape">https://learn.flucoma.org/reference/spectralshape</a>
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='signal'>
            <digest>Audio and control in
</digest>
            <description>Audio input to be analyzed for concatenation/resynthesis.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='list'>
            <digest>Descriptors and statistics output as <o>buffer~</o>
</digest>
            <description>The nearest match in the pre-trained classifier.
</description>
        </outlet>
        <outlet id='1' type='list'>
            <digest>Current rate
</digest>
            <description>Current rate in <strong>ms</strong> of the internal clocking.
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='random'
        type='int'
        size='1'
        get='1' set='1'
        >
        <digest>Enable random rate matching
</digest>
        <description>Enable random variation to the matching/concatenation.
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='rate'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Rate of concatenation
</digest>
        <description>Rate of matching/playback in the concatenation engine (in %).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='100'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
	<!--ATTRIBUTES-->

	<!-- SEEALSO -->
	<seealsolist>
        <seealso name='dk.concatcreate' />
        <seealso name='dk.concatmatch' />
        <seealso name='dk.concatplayer~' />
        <seealso name='dk.concatsynth~' />
	</seealsolist>
	<!-- SEEALSO -->
</c74object>