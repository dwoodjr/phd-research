<c74object name='dk.triggeralign~' category='' module='dataknot'>
    <digest>Trigger alignment based on descriptor analysis latency
</digest>
    <description>The <o>dk.triggeralign~</o> object takes a gate input and time-aligns it to any message-based input in the left inlet. This is primarily useful for delaying triggers/gates so they line up with non-deterministic processes like descriptor analysis or corpus queries.
</description>
    <discussion>This is as accurate as possible within Max since it will wait until the descriptor analysis is done before sending out the corresponding trigger/gate. It is impossible to do this sample-accuratey since the descriptor analysis itself can take an unknown amount of time.
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='list'>
            <digest>Descriptor in
</digest>
            <description>Descriptor input.
</description>
        </inlet>
        <inlet id='1' type='signal'>
            <digest>Gate in
</digest>
            <description>Gate input from <o>dk.onsetframe~.</o>
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='signal'>
            <digest>Trigger out
</digest>
            <description>Time-aligned trigger output.
</description>
        </outlet>
        <outlet id='1' type='signal'>
            <digest>Gate out
</digest>
            <description>Time-aligned gate output.
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
	</methodlist>
	<!--MESSAGES-->

