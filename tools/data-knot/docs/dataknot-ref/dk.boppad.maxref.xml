<?xml version='1.0' encoding='utf-8' standalone='yes'?>
<?xml-stylesheet href="./_c74_ref.xsl" type="text/xsl"?>

<c74object name='dk.boppad' category='' module='dataknot'>
    <digest>Interface for the KMI BopPad
</digest>
    <description>The <o>dk.boppad</o> object acts as a parser for the Keith McMillen BopPad. It outputs note/velocity pairs, XY coordinates in a grid-ified space, and pressure/aftertouch.
</description>
    <discussion>All of this is coded around a specific mapping being loaded onto the BopPad. There is now an included &quot;boppad_preset.json&quot; file in the /misc folder of the package that can be uploaded to your BopPad with the BopPad editor by dragging it onto the preset window.
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='list'>
            <digest>Control in
</digest>
            <description>Control input.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='list'>
            <digest>Note and velocity
</digest>
            <description>MIDI note and velocity.
</description>
        </outlet>
        <outlet id='1' type='list'>
            <digest>Grid position
</digest>
            <description>Grid position as XY pair.
</description>
        </outlet>
        <outlet id='2' type='list'>
            <digest>Pressure
</digest>
            <description>Pressure output.
</description>
        </outlet>
        <outlet id='3' type='list'>
            <digest>Global parameters
</digest>
            <description>Global parameter output.
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='spread'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Amount of random spread applied per quadrant
</digest>
        <description>Amount of random spread applied per quadrant, based on the radius.
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='50'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
	<!--ATTRIBUTES-->

	<!-- SEEALSO -->
	<seealsolist>
        <seealso name='dk.eraetouch' />
        <seealso name='dk.gridmatch' />
        <seealso name='dk.gridscale' />
	</seealsolist>
	<!-- SEEALSO -->
</c74object>