<c74object name='dk.datagranular' category='' module='dataknot'>
    <digest>Repeat and vary incoming descriptor data like a &#39;granular synth&#39;
</digest>
    <description>The <o>dk.datagranular</o> object takes incoming descriptor data (of any kind) and processes it through a &#39;granular synth&#39;-style process. The input can be lists or <o>buffer~</o> s and the same will be output.
</description>
    <discussion>The underlying <at>variation</at> attribute is proportional to the range of the feature, meaning it will transform descriptors that are in larger units (e.g. decibels) more than it does smaller ones (e.g. derivatives).
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='list'>
            <digest>Descriptor and control in
</digest>
            <description>Incoming descriptors as a list or <o>buffer~</o> as well as control input.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='list'>
            <digest>Descriptor output
</digest>
            <description>Transformed descriptor output.
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='active'
        type='int'
        size='1'
        get='1' set='1'
        >
        <digest>Enable the granular process
</digest>
        <description>Enables/disables the granular process.
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='random'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Enable random timing in the <at>rate</at>
</digest>
        <description>Enable random timing variations in the <m>rate.</m>
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='rate'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Rate of repetition
</digest>
        <description>Rate of the repetition in <strong>ms</strong>.
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='50'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='variation'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Amount of variation in each repetition
</digest>
        <description>Amount of variation in each repeating &#39;grain&#39;, in <strong>%</strong>.
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
	<!--ATTRIBUTES-->

