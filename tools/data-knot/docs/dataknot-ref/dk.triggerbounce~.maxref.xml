<c74object name='dk.triggerbounce~' category='' module='dataknot'>
    <digest>Bouncing ball pattern of triggers and gates
</digest>
    <description>The <o>dk.triggerbounce~</o> object creates a series of triggers (or gates) after each input based on a duration, amount of &quot;bounces&quot;, and the curve. Can be used to trigger more processes down the line.
</description>
    <discussion>When working with hardware instruments it may be required to use <o>dk.triggerlength~</o> to make the single sample triggers from MSP register correctly. A trigger length of 5-10ms works fairly well across all equipment I have tested.
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='signal'>
            <digest>Trigger/gate and control in
</digest>
            <description>Trigger/gate and control in.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='signal'>
            <digest>Trigger/gate output
</digest>
            <description>Trigger/gate output.
</description>
        </outlet>
        <outlet id='1' type='signal'>
            <digest>Trigger when bounces complete
</digest>
            <description>Trigger when bounces complete.
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
    <method name='bang'>
        <arglist>
        </arglist>
        <digest>Equivalent to sending a trigger
</digest>
        <description>Equivalent of sending a trigger to the inlet.
</description>
    </method>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='bounces'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Amount of bounces to happen in given duration
</digest>
        <description>Amount of bounces to happen in given duration.
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='12'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='curve'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Curve for timing of &#39;bounces&#39; (0% = linear, -100% = speeding up, 100% = speeding down)
</digest>
        <description>Curve for timing of &#39;bounces&#39; (0% = linear, -100% = speeding up, 100% = speeding down).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='70'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='duration'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Duration of bounces (ms)
</digest>
        <description>Duration of bounces (ms).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='400'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='retrigger'
        type='int'
        size='1'
        get='1' set='1'
        >
        <digest>Whether you can retrigger a new series of bounces before it has finished
</digest>
        <description>Whether you can retrigger a new series of bounces before it has finished.
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='1'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
	<!--ATTRIBUTES-->

