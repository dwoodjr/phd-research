<?xml version='1.0' encoding='utf-8' standalone='yes'?>
<?xml-stylesheet href="./_c74_ref.xsl" type="text/xsl"?>

<c74object name='dk.speed' category='' module='dataknot'>
    <digest>Extract timing and speed parameters from onsets
</digest>
    <description>The <o>dk.speed</o> object works in conjunction with <o>dk.onset~</o> to create several parameters based on the time between attacks.
</description>
    <discussion>Originally inspired by the Sensory Percussion &quot;speed&quot; modulator, but the expanded to incorporate additional parameters derived in a similar way.
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='list'>
            <digest>Incoming bang, list, or <o>buffer~</o> in
</digest>
            <description>Incoming bang, list, or <o>buffer~</o> input.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='list'>
            <digest>Speed meta-parameters out
</digest>
            <description>Speed meta-parameters output.
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='history'
        type='int'
        size='1'
        get='1' set='1'
        >
        <digest>Amount of delta values to compute on
</digest>
        <description>Amount of delta values to compute on.
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='7'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='select'
        type='list'
        size='5'
        get='1' set='1'
        >
        <digest>Select a subset of descriptors to pass through
</digest>
        <description>Allow only a subset of the descriptors to come out. A message of &quot;select reset&quot; will return everything to default.
</description>

        <attributelist>
            <attribute
            name='default'
            type='list'
            size='5'
            value='speed, tempo, slope, variance, direction'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='slew'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Amount of smoothing to apply to speed output (in ms)
</digest>
        <description>Amount of smoothing to apply to speed output (in ms).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='500'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
	<!--ATTRIBUTES-->

	<!-- SEEALSO -->
	<seealsolist>
        <seealso name='dk.controllers' />
        <seealso name='dk.novelty~' />
        <seealso name='dk.onset~' />
        <seealso name='dk.spectralonset~' />
	</seealsolist>
	<!-- SEEALSO -->
</c74object>