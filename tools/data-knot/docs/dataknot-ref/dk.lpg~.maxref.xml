<?xml version='1.0' encoding='utf-8' standalone='yes'?>
<?xml-stylesheet href="./_c74_ref.xsl" type="text/xsl"?>

<c74object name='dk.lpg~' category='' module='dataknot'>
    <digest>Vactrol/low pass gate model
</digest>
    <description>The <o>dk.lpg~</o> object is an implementation of a low pass gate, which rolls back the harmonics as well as cutting the volume based on a vactrol model.
</description>
    <discussion>Adapted from code taken from a paper by Julian Parker and Stefano D’Angelo <a href="http://research.spa.aalto.fi/publications/papers/dafx13-lpg/">http://research.spa.aalto.fi/publications/papers/dafx13-lpg/</a>
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='signal'>
            <digest>Audio and control input
</digest>
            <description>Audio and control input.
</description>
        </inlet>
        <inlet id='1' type='signal'>
            <digest>Trigger/gate input
</digest>
            <description>Trigger/gate input.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='signal'>
            <digest>Audio output
</digest>
            <description>Audio output.
</description>
        </outlet>
        <outlet id='1' type='signal'>
            <digest>Envelope output
</digest>
            <description>Envelope output.
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
    <method name='bang'>
        <arglist>
        </arglist>
        <digest>Equivalent of sending a trigger when sent into right inlet
</digest>
        <description>Equivalent of sending a trigger when sent into right inlet.
</description>
    </method>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='duration'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Duration of low pass gate in ms
</digest>
        <description>Duration of low pass gate in ms (natural vactrol duration is ~2000ms).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='500'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='offset'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Offset for incoming signal to further drive lpg
</digest>
        <description>Offset for incoming signal to further drive or activate the lpg (in %).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='offsetmute'
        type='int'
        size='1'
        get='1' set='1'
        >
        <digest>Mutes lpg output regardless of offset setting
</digest>
        <description>Mutes lpg output regardless of offset setting, allowing for manual control of lpg filter.
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='1'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='lowpass'
        type='int'
        size='1'
        get='1' set='1'
        >
        <digest>Enables low pass mode
</digest>
        <description>Enables low pass mode (0/1).
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='nonlinear'
        type='int'
        size='1'
        get='1' set='1'
        >
        <digest>Enables nonlinear processing
</digest>
        <description>Enables nonlinear processing (0/1).
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='resonance'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Filter resonance when in low pass mode
</digest>
        <description>Filter resonance when in low pass mode (in %)
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='vcaness'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Character of envelope
</digest>
        <description>Character of envelope (lpg vs vca) (0-100).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
	<!--ATTRIBUTES-->

	<!-- SEEALSO -->
	<seealsolist>
        <seealso name='dk.convolver~' />
        <seealso name='dk.crosstalk~' />
        <seealso name='dk.envelope~' />
