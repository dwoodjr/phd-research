<c74object name='dk.concatplayer~' category='' module='dataknot'>
    <digest>Granular playback engine
</digest>
    <description>The <o>dk.concatplayer~</o> object is the underlying playback engine for <o>dk.concatsynth~.</o> It is a stripped-back granular synth engine that plays back small and windowed fragments of a single large <o>buffer~</o> unlike the corpus-based playback elsewhere in Data Knot.
</description>
    <discussion>If you want to learn more about the underlying algorithm have a look at this article:<br/><a href="https://learn.flucoma.org/reference/kdtree">https://learn.flucoma.org/reference/kdtree</a>
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='list'>
            <digest>Position and <o>buffer~</o> to play from
</digest>
            <description>Position (offset in <strong>ms</strong>) and <o>buffer~</o> name to play back from.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='signal'>
            <digest>Audio output (left)
</digest>
            <description>Audio output (left).
</description>
        </outlet>
        <outlet id='1' type='signal'>
            <digest>Audio output (right)
</digest>
            <description>Audio output (right).
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='loudnesscomp'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Amount of loudness compensation to apply
</digest>
        <description>Amount of loudness compensation to apply (bewteen -100 and 100%).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='50'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='pitchcomp'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Amount of pitch compensation to apply
</digest>
        <description>Amount of pitch compensation to apply (between -100 and 100%).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='rate'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Rate of concatenation
</digest>
        <description>Rate of matching/playback in the concatenation engine (in %).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='100'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='size'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Size of grain to play back
</digest>
        <description>Size of grain to play back, in %.
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='100'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='speed'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Playback speed
</digest>
        <description>Sets the playback speed for each individual grain.
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='100'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='steal'
        type='int'
        size='1'
        get='1' set='1'
        >
        <digest>Whether poly voice stealing is enabled
</digest>
        <description>Sets whether voice stealing is enabled, which allows new samples to start when previous ones are still sounding.
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='1'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='width'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Panning width
</digest>
        <description>Sets the random distribution width for the grain panning.
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='100'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='window'
        type='symbol'
        size='1'
        get='1' set='1'
        >
        <digest>Window function for playback
</digest>
        <description>Sets the window function for the grain playback.&quot;
The available options are:
<strong>sine</strong>
<strong>hann</strong>
<strong>triangle</strong>
<strong>rampdown</strong>
<strong>rampup</strong>
<strong>onset</strong>
<strong>hamming</strong>
<strong>blackman</strong>
<strong>square</strong>
</description>

        <attributelist>
            <attribute
            name='default'
            type='symbol'
            size='1'
            value='sine'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='voices'
        type='int'
        size='1'
        get='1' set='1'
        >
        <digest>Amount of polyphony
</digest>
        <description>Sets the amount of polyphony available for sample playback.
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='64'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
	<!--ATTRIBUTES-->

