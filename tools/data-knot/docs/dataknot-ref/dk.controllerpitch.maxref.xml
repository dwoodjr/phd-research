<c74object name='dk.controllerpitch' category='' module='dataknot'>
    <digest>Map pitches across a range in a given key/scale
</digest>
    <description>The <o>dk.controllerpitch</o> object takes incoming values (between 0. and 1.) and maps them across a specified range, including scale/key quantization. This is useful for creating melodic gestures from incoming descriptor or controller data.
</description>
    <discussion>Originally inspired by Sensory Percussion modulators, but the expanded to incorporate additional parameters derived in a similar way.
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='float'>
            <digest>Controller in
</digest>
            <description>Controller input.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='float'>
            <digest>Quantized notes
</digest>
            <description>Quantized MIDI note output.
</description>
        </outlet>
        <outlet id='1' type='int'>
            <digest>Display output for <o>kslider</o>
</digest>
            <description>Display output for <o>kslider.</o>
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
