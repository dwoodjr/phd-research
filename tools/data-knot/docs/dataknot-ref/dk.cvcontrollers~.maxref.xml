<c74object name='dk.cvcontrollers~' category='' module='dataknot'>
    <digest>Extract meta-signals from control voltage input
</digest>
    <description>The <o>dk.cvcontrollers~</o> object creates several meta-signals from control voltage input that can be used to create varied, but still related, control signals.
</description>
    <discussion>This can be used to process MSP signals or actual CV/triggers/gates from modular hardware. This can be accomplished with any DC-coupled audio interface or with specialist hardware like Expert-Sleepers interfaces<br/><a href="http://expert-sleepers.co.uk">http://expert-sleepers.co.uk</a>
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='signal'>
            <digest>Trigger/gate and control in
</digest>
            <description>Trigger/gate and control in.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='signal'>
            <digest>Trigger/gate output
</digest>
            <description>Trigger/gate output.
</description>
        </outlet>
        <outlet id='1' type='signal'>
            <digest>Trigger when cloud completes
</digest>
            <description>Trigger when cloud completes.
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='attack'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Attack time of signal
</digest>
        <description>Attack time of signal (in ms).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='25'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='lockout'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Time before an onset can be triggered again
</digest>
        <description>Time before an onset can be triggered again (in ms).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='100'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='offset'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Offset of signal
</digest>
        <description>Offset of signal (in %).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='0'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='onsetmode'
        type='symbol'
        size='1'
        get='1' set='1'
        >
        <digest>Selects between threshold and direction changes
</digest>
        <description>Selects between threshold and direction changes to base timing calculations on.
</description>

        <attributelist>
            <attribute
            name='default'
            type='symbol'
            size='1'
            value='direction'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='polarity'
        type='symbol'
        size='1'
        get='1' set='1'
        >
        <digest>Sets input range
</digest>
        <description>Sets the input range of the CV between unipoar (0 to 1) or bipolar (-1 to 1).
</description>

        <attributelist>
            <attribute
            name='default'
            type='symbol'
            size='1'
            value='unipolar'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='release'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Release time of signal
</digest>
        <description>Release time of signal (in ms).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='50'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='scale'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Scale of signal
</digest>
        <description>Scale of signal (in %).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='100'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='sensitivity'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Sets the sensitivity of the thresholding for the gate output
</digest>
        <description>Sets the sensitivity of the thresholding for the gate output (in %).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='75'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='slew'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Smoothing applied to input signal
</digest>
        <description>Smoothing applied to input signal (in ms).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='10'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='speedslew'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Smoothing applied to the &quot;speed&quot; meta-parameter
</digest>
        <description>Smoothing applied to the &quot;speed&quot; meta-parameter (in ms).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='500'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
