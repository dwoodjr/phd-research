<c74object name='dk.shaker~' category='' module='dataknot'>
    <digest>Physical model of a maraca/shaker
</digest>
    <description>The <o>dk.shaker~</o> object is a physical model of a maraca. It can also be used to create hi-hat or snare sounds depending on the settings. The model is activated by a generated impulse, live input, or a combination of both, which serves to further shape the resultant sound.
</description>
    <discussion>The <o>dk.shaker~</o> object is a physical model of a maraca. It can also be used to create hi-hat or snare sounds depending on the settings. The model is activated by a generated impulse, live input, or a combination of both, which serves to further shape the resultant sound.
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='signal'>
            <digest>Note input and optional audio input
</digest>
            <description>Note input (as MIDI float) and optional audio input for triggering the algorithm.
</description>
        </inlet>
        <inlet id='1' type='signal'>
            <digest>Trigger input
</digest>
            <description>Trigger input.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='signal'>
            <digest>Audio output
</digest>
            <description>Audio output.
</description>
        </outlet>
        <outlet id='1' type='signal'>
            <digest>Impulse output
</digest>
            <description>Impulse that is fed to algorithm output.
</description>
        </outlet>
        <outlet id='2' type='list'>
            <digest>Dump out for parameter names, ranges, and values
</digest>
            <description>Dump out for parameter names, ranges, and values.
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
    <method name='dump'>
        <arglist>
        </arglist>
        <digest>Dump parameter names, ranges, and values
</digest>
        <description>Dumps parameter names, ranges, and values out of the right-most outlet.
</description>
    </method>
    <method name='randomize'>
        <arglist>
        </arglist>
        <digest>Randomize parameters
</digest>
        <description>Randomize parameters defined by the preset dictionary. An additional optional argument will randomize by a certain percentage.
</description>
    </method>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='frequency'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Resonant frequency of the model
</digest>
        <description>Resonant frequency of the model.
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='3200'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='gain'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Output gain
</digest>
        <description>Output gain (in %).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='100'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='impulse'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Amount of impulse signal sent to algorithm
</digest>
        <description>Amount of impulse signal sent to algorithm.
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='50'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='input'
        type='float'
        size='1'
        get='1' set='1'
