            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='mode'
        type='list'
        size='1'
        get='1' set='1'
        >
        <digest>Sets the actuation mode for audio input
</digest>
        <description>Sets the actuation mode for audio input.<br/>
The available options are:<br/>
<ul>
<li><strong>0</strong> = no direct audio, triggers only</li>
<li><strong>1</strong> = direct audio only, no triggers</li>
<li><strong>2</strong> = both direct and trigger audio)</li>
</ul>
</description>

        <attributelist>
            <attribute
            name='default'
            type='list'
            size='1'
            value=''
            get='1' set='1'
            />
        </attributelist>
        </attribute>
