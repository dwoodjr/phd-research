<c74object name='dk.descriptordisplay' category='' module='dataknot'>
    <digest>Displays incoming descriptors
</digest>
    <description>The <o>dk.descriptordisplay</o> object displays incoming descriptors while adapting to every descriptor type.
</description>
    <discussion>Works with lists or <o>buffer~</o> and will output in the same format it receives.
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='list'>
            <digest>Descriptor input
</digest>
            <description>Incoming descriptors as a list or <o>buffer~.</o>
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='list'>
            <digest>Descriptor output
</digest>
            <description>Descriptor thru as a list or <o>buffer~.</o>
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='size'
        type='symbol'
        size='1'
        get='1' set='1'
        >
        <digest>Display size of UI
</digest>
        <description>Display size of UI (small: 169, medium: 235, large: 350).
</description>

        <attributelist>
            <attribute
            name='default'
            type='symbol'
            size='1'
            value='medium'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
	<!--ATTRIBUTES-->

	<!-- SEEALSO -->
	<seealsolist>
        <seealso name='dk.classifierdisplay' />
        <seealso name='dk.controllers' />
        <seealso name='dk.corpuslist' />
        <seealso name='dk.descriptors~' />
        <seealso name='dk.melbands~' />
        <seealso name='dk.mfcc~' />
        <seealso name='dk.sines~' />
        <seealso name='dk.spectralshape~' />
        <seealso name='dk.speed' />
        <seealso name='dk.plotter' />
	</seealsolist>
	<!-- SEEALSO -->
</c74object>