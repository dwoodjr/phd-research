</digest>
            <description>Audio output (L).
</description>
        </outlet>
        <outlet id='1' type='signal'>
            <digest>Audio output (R)
</digest>
            <description>Audio output (R).
</description>
        </outlet>
        <outlet id='2' type='signal'>
            <digest>Impulse output
</digest>
            <description>Impulse that is fed to algorithm output.
</description>
        </outlet>
        <outlet id='3' type='list'>
            <digest>Dump out for parameter names, ranges, and values
</digest>
            <description>Dump out for parameter names, ranges, and values.
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

