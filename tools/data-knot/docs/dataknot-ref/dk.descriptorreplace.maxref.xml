<c74object name='dk.descriptorreplace' category='' module='dataknot'>
    <digest>Replace descriptors from descriptor list or buffer
</digest>
    <description>The <o>dk.descriptorreplace</o> object takes incoming descriptors (as list or buffer) from <o>dk.descriptors~</o>/<o>dk.descriptorframe</o> and replace any of the four main descriptors within it (loudness, centroid, flatness, and pitch).
</description>
    <discussion>This works especially well when analyzing audio that has little to no meaningful information within a descriptor type, like pitch on drums.
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='list'>
            <digest>Descriptor and control in
</digest>
            <description>Descriptor input as list or <o>buffer~.</o>
</description>
        </inlet>
        <inlet id='1' type='list'>
            <digest>Replacement descriptors
</digest>
            <description>Descriptors to use as replacements, as list or <o>buffer~.</o>
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='list'>
            <digest>Descriptor output
</digest>
            <description>Descriptor output (as list or <o>buffer~</o>).
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='replace'
        type='list'
        size='1'
        get='1' set='1'
        >
        <digest>What descriptor(s) to replace
</digest>
        <description>What descriptor(s) to replace (loudness, centroid, flatness, pitch)
</description>

        <attributelist>
            <attribute
            name='default'
            type='list'
            size='4'
            value='pitch'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
	<!--ATTRIBUTES-->

	<!-- SEEALSO -->
	<seealsolist>
        <seealso name='dk.descriptorcurves' />
        <seealso name='dk.descriptors~' />
        <seealso name='dk.filter' />
        <seealso name='dk.gridscale' />
        <seealso name='dk.quantizepitch' />
        <seealso name='dk.schmitt' />
	</seealsolist>
	<!-- SEEALSO -->
</c74object>