<?xml version='1.0' encoding='utf-8' standalone='yes'?>
<?xml-stylesheet href="./_c74_ref.xsl" type="text/xsl"?>

<c74object name='dk.probability~' category='' module='dataknot'>
    <digest>Probability-based message filter
</digest>
    <description>The <o>dk.probability~</o> object only passes a certain amount of the incoming messages, which can be bangs, lists, buffers, triggers, or gates. This can be either probability or counting based, or a combination of both. The messages that are not passed are sent to alternate outputs.
</description>
    <discussion>Although you can send in bangs as well as triggers/gates, when sending in a bang, only a bang will come out and not a trigger/gate as well.
</discussion>

	<metadatalist>
		<metadata name='author'>Rodrigo Constanzo, FluCoMa Project</metadata>
		<metadata name='tag'>Machine Learning</metadata>
		<metadata name='tag'>Audio Analysis</metadata>
		<metadata name='tag'>Onset Detection</metadata>
		<metadata name='tag'>Corpus Playback</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
        <inlet id='0' type='signal'>
            <digest>Input to filter
</digest>
            <description>Input to filter (can be bangs, lists, buffers, triggers, or gates).
</description>
        </inlet>
        <inlet id='1' type='signal'>
            <digest>Trigger input
</digest>
            <description>Trigger input.
</description>
        </inlet>
    </inletlist>
    <!-- INLETS -->

    <!-- OUTLETS -->
    <outletlist>
        <outlet id='0' type='list'>
            <digest>Bangs/lists/buffer output
</digest>
            <description>Bangs/lists/buffer output.
</description>
        </outlet>
        <outlet id='1' type='signal'>
            <digest>Trigger/gate output
</digest>
            <description>Trigger/gate output.
</description>
        </outlet>
        <outlet id='2' type='list'>
            <digest>Bangs/lists/buffer output (not passed)
</digest>
            <description>Bangs/lists/buffer output (not passed).
</description>
        </outlet>
        <outlet id='3' type='signal'>
            <digest>Trigger/gate output (not passed)
</digest>
            <description>Trigger/gate output (not passed).
</description>
        </outlet>
    </outletlist>
    <!-- OUTLETS -->

    <!-- ARGUMENTS -->
    <objarglist>
        <objarg name='probability' optional='1' type='number'>
            <digest>Probability of input passing through (in %)
</digest>
            <description>Probability of input passing through (in %).
</description>
        </objarg>
    </objarglist>
    <!-- ARGUMENTS -->

    <!--MESSAGES-->
    <methodlist>
	</methodlist>
	<!--MESSAGES-->

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute
        name='every'
        type='int'
        size='1'
        get='1' set='1'
        >
        <digest>Lets every nth message through
</digest>
        <description>Lets every nth message through (minimum 1).
</description>

        <attributelist>
            <attribute
            name='default'
            type='int'
            size='1'
            value='1'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
        <attribute
        name='probability'
        type='float'
        size='1'
        get='1' set='1'
        >
        <digest>Probability of input passing through (in %)
</digest>
        <description>Probability of input passing through (in %).
</description>

        <attributelist>
            <attribute
            name='default'
            type='float'
            size='1'
            value='100'
            get='1' set='1'
            />
        </attributelist>
        </attribute>
	</attributelist>
	<!--ATTRIBUTES-->

	<!-- SEEALSO -->
	<seealsolist>
        <seealso name='dk.novelty~' />
        <seealso name='dk.onset~' />
        <seealso name='dk.spectralonset~' />
        <seealso name='dk.triggerbounce~' />
        <seealso name='dk.triggercloud~' />
        <seealso name='dk.triggershape~' />
	</seealsolist>
	<!-- SEEALSO -->
</c74object>