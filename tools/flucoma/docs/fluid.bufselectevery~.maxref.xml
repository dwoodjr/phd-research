<c74object name='fluid.bufselectevery~' category='FluidCorpusManipulation'>
	<digest>Extract every N samples / channels from a buffer</digest>
	<description>Pick every N frames and / or channels from a buffer, described in terms of independent hop sizes for frames and channels</description>
  <discussion>
    <h4><openfilelink filename="Fluid Corpus Manipulation Toolkit.maxpat">Open the Overview Patch</openfilelink></h4>
            
    <p>Read more about fluid.bufselectevery~ on the <a href='https://learn.flucoma.org/reference/bufselectevery'>learn platform</a>.</p>
    <p>fluid.bufselectevery~ is part of the Fluid Decomposition Toolkit of the FluCoMa project. For more explanations, learning material, and discussions on its musicianly uses, visit <a href="http://www.flucoma.org/">flucoma.org</a>.</p>
  </discussion>
	<!--METADATA-->
	<metadatalist>
		<metadata name='author'>FluCoMa</metadata>
		<metadata name='tag'>Fluid Decomposition</metadata>
		<metadata name='tag'>corpus</metadata>
	</metadatalist>
	<!--ARGUMENTS-->
	<objarglist>
	</objarglist>
	<!--MESSAGES-->
  <methodlist><method name="bang">
     <arglist />
     <digest>
       Trigger processing
     </digest>
     <description>
       A bang will commence processing on object given its current settings, unless it is already busy. In that case, the behaviour depends on the value of the <m>queue</m> attribute.
     </description>
   </method>
   <method name="cancel">
     <arglist />
     <digest>
       Cancel non-blocking processing
     </digest>
     <description>
       When processing in non-blocking mode, this will cancel the job underway, without updating destination buffers.
     </description>
   </method><method name="reset">
      <arglist />
      <digest>
        Return the object to its original state
      </digest>
      <description>
        Calling <m>reset</m> will change parameter values back to those the object was <i>created</i> with, i.e. any attribute values set in the box will be retained
      </description>
    </method></methodlist>
	<!--ATTRIBUTES-->
	<attributelist><attribute name='chanhop' get='1' set='1' type='int' size='1'>
        <digest>
              Channel Hop
        </digest>
        <description>
              <p>Take every <m>chanhop</m> channels. Default = 1 = all channels (where 2 would be every other channel, etc.)</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='1' /></attributelist></attribute><attribute name='destination' get='1' set='1' type='symbol' size='1'>
        <digest>
              Destination Buffer
        </digest>
        <description>
              <p>The <o>buffer~</o> to write the selected data to</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='None' /></attributelist></attribute><attribute name='framehop' get='1' set='1' type='int' size='1'>
        <digest>
              Frame Hop
        </digest>
        <description>
              <p>Take every <m>framehop</m> frames. Default = 1 = all frames (where 2 would be every other frame, etc.)</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='1' /></attributelist></attribute><attribute name='numchans' get='1' set='1' type='int' size='1'>
        <digest>
              Source Number of Channels
        </digest>
        <description>
              <p>The number of channels from which to copy in the source buffer.</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='-1' /></attributelist></attribute><attribute name='numframes' get='1' set='1' type='int' size='1'>
        <digest>
              Source Number of Frames
        </digest>
        <description>
              <p>The duration (in samples) to copy from the source buffer. The default (-1) copies the full length of the buffer.</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='-1' /></attributelist></attribute><attribute name='source' get='1' set='1' type='symbol' size='1'>
        <digest>
              Source Buffer
        </digest>
        <description>
              <p>The <o>buffer~</o> to pick values from</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='None' /></attributelist></attribute><attribute name='startchan' get='1' set='1' type='int' size='1'>
        <digest>
              Source Channel Offset
        </digest>
        <description>
              <p>The first channel from which to copy in the source buffer.</p>
    <p><strong>Constraints</strong></p>
    <ul class="simple">
    <li>Minimum: <m>0</m></li>
    </ul>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='0' /></attributelist></attribute><attribute name='startframe' get='1' set='1' type='int' size='1'>
        <digest>
              Source Offset
        </digest>
        <description>
              <p>The starting point (in samples) from which to copy in the source buffer.</p>
    <p><strong>Constraints</strong></p>
    <ul class="simple">
    <li>Minimum: <m>0</m></li>
    </ul>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='0' /></attributelist></attribute><attribute name='warnings' get='1' set='1' type='int' size='1'>
        <digest>
              Warnings
        </digest>
        <description>
              <p>Enable warnings to be issued whenever a parameter value is constrained (e.g. clipped)</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='0' /></attributelist></attribute></attributelist>
