	<!--ATTRIBUTES-->
	<attributelist><attribute name='destination' get='1' set='1' type='symbol' size='1'>
        <digest>
              Destination Buffer
        </digest>
        <description>
              <p>buffer for interpolated audio</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='None' /></attributelist></attribute><attribute name='fftsettings' get='1' set='1' type='int' size='4'>
        <digest>
              FFT Settings
        </digest>
        <description>
              <p>FFT settings consist of three numbers representing the window size, hop size and FFT size in samples:</p>
    <p>The hop size and fft size can both be set to -1 (and are by default), with slightly different meanings:</p>
    <ul class="simple">
    <li>For the hop size, -1 = <m>windowsize/2</m></li>
    <li>For the FFT size, -1 = <m>windowsize</m> snapped to the nearest equal / greater power of 2 (e.g. <m>windowsize 1024</m> =&gt; <m>fftsize 1024</m>, but <m>windowssize 1000</m> also =&gt; <m>fftsize 1024</m>)</li>
    </ul>
    <p><strong>Constraints</strong></p>
    <ul class="simple">
    <li>FFTSize, if != -1, will snap to the next greatest power of two &amp;gt; 4</li>
    <li>The maximum FFT size is limited to the value of the <m>maxfftsize</m> argument</li>
    <li>if FFT size != -1, then window size is clipped at FFT size</li>
    </ul>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='4' value='[[&#39;winSize&#39;, 1024], [&#39;hopSize&#39;, -1], [&#39;fftSize&#39;, -1]]' /></attributelist></attribute><attribute name='interpolation' get='1' set='1' type='float64' size='1'>
        <digest>
              Interpolation
        </digest>
        <description>
              <p>The amount to interpolate between A and B (0-1, 0 = A, 1 = B)</p>
    <p><strong>Constraints</strong></p>
    <ul class="simple">
    <li>Minimum: <m>0.0</m></li>
    <li>Maximum: <m>1.0</m></li>
    </ul>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='0.0' /></attributelist></attribute><attribute name='maxfftsize' get='1' set='1' type='int' size='1'>
        <digest>
              Maximum FFT Size
        </digest>
        <description>
              <p>Set an explicit upper bound on the FFT size at object instantiation. The default of -1 sets this to whatever the initial FFT size is</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='-1' /></attributelist></attribute><attribute name='numchansa' get='1' set='1' type='int' size='1'>
        <digest>
              Source A Number of Channels
        </digest>
        <description>
              <p>number of channels to process in first source buffer</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='-1' /></attributelist></attribute><attribute name='numchansb' get='1' set='1' type='int' size='1'>
        <digest>
              Source B Number of Channels
        </digest>
        <description>
              <p>number of channels to process in second buffer</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='-1' /></attributelist></attribute><attribute name='numframesa' get='1' set='1' type='int' size='1'>
        <digest>
              Source A Number of Frames
        </digest>
        <description>
              <p>number of samples to use from first source buffer</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='-1' /></attributelist></attribute><attribute name='numframesb' get='1' set='1' type='int' size='1'>
        <digest>
              Source B Number of Frames
        </digest>
        <description>
              <p>number of samples to process from second buffer</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='-1' /></attributelist></attribute><attribute name='sourcea' get='1' set='1' type='symbol' size='1'>
        <digest>
              Source Buffer A
        </digest>
        <description>
              <p>The first source buffer</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='None' /></attributelist></attribute><attribute name='sourceb' get='1' set='1' type='symbol' size='1'>
        <digest>
              Source Buffer B
        </digest>
        <description>
              <p>the second source buffer</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='None' /></attributelist></attribute><attribute name='startchana' get='1' set='1' type='int' size='1'>
        <digest>
              Source A Start Channel
        </digest>
        <description>
              <p>starting channel of first source buffer</p>
    <p><strong>Constraints</strong></p>
    <ul class="simple">
    <li>Minimum: <m>0</m></li>
    </ul>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='0' /></attributelist></attribute><attribute name='startchanb' get='1' set='1' type='int' size='1'>
        <digest>
              Source B Start Channel
        </digest>
        <description>
              <p>starting channel for second buffer</p>
    <p><strong>Constraints</strong></p>
    <ul class="simple">
    <li>Minimum: <m>0</m></li>
    </ul>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='0' /></attributelist></attribute><attribute name='startframea' get='1' set='1' type='int' size='1'>
        <digest>
              Source A Offset
        </digest>
        <description>
              <p>offset into the first source buffer (samples)</p>
    <p><strong>Constraints</strong></p>
    <ul class="simple">
    <li>Minimum: <m>0</m></li>
    </ul>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='0' /></attributelist></attribute><attribute name='startframeb' get='1' set='1' type='int' size='1'>
        <digest>
              Source B Offset
        </digest>
        <description>
              <p>offset into the second source buffer (samples)</p>
    <p><strong>Constraints</strong></p>
    <ul class="simple">
    <li>Minimum: <m>0</m></li>
    </ul>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='0' /></attributelist></attribute><attribute name='warnings' get='1' set='1' type='int' size='1'>
        <digest>
              Warnings
        </digest>
        <description>
              <p>Enable warnings to be issued whenever a parameter value is constrained (e.g. clipped)</p>

          
        </description><attributelist><attribute name="default" get="1" set="1" type="int" size='1' value='0' /></attributelist></attribute></attributelist>
