<c74object name='fluid.datasetquery~' category='FluidCorpusManipulation'>
	<digest>Query a FluidDataSet</digest>
	<description>A selection of columns and a set of conditions that match points in a FluidDataSet. Used to filter and search in a database of descriptors.</description>
  <discussion>
    <h4><openfilelink filename="Fluid Corpus Manipulation Toolkit.maxpat">Open the Overview Patch</openfilelink></h4>
            
    <p>Read more about fluid.datasetquery~ on the <a href='https://learn.flucoma.org/reference/datasetquery'>learn platform</a>.</p>
    <p>fluid.datasetquery~ is part of the Fluid Decomposition Toolkit of the FluCoMa project. For more explanations, learning material, and discussions on its musicianly uses, visit <a href="http://www.flucoma.org/">flucoma.org</a>.</p>
  </discussion>
	<!--METADATA-->
	<metadatalist>
		<metadata name='author'>FluCoMa</metadata>
		<metadata name='tag'>Fluid Decomposition</metadata>
		<metadata name='tag'>corpus</metadata>
	</metadatalist>
	<!--ARGUMENTS-->
	<objarglist>
	</objarglist>
	<!--MESSAGES-->
  <methodlist><method name="reset">
      <arglist />
      <digest>
        Return the object to its original state
      </digest>
      <description>
        Calling <m>reset</m> will change parameter values back to those the object was <i>created</i> with, i.e. any attribute values set in the box will be retained
      </description>
    </method><method name='refer'>
     <arglist>
     <arg name="name" optional="0" type='symbol'/>
     </arglist>
     <description>Changes the reference to the data in another named fluid.datasetquery~ object. Changes to the data stored in any referenced will be shared by all other similarly named fluid.datasetquery~ objects.</description>
   </method>    <method name='transform'>
			<arglist><arg name= "sourceDataSet" optional='0' type="Unknown Type (input dataset)" /><arg name= "destDataSet" optional='0' type="symbol" /></arglist>
			<description>
            <p>Apply the query to a source <o>
    fluid.dataset~</o> and write to a destination. Can be passed the same for input and output (in-place).</p>

        
<h5>Argument details:</h5>        <ul><li>sourceDataSet: <p>Source data, or the DataSet name</p>
</li><li>destDataSet: <p>Destination data, or the DataSet name</p>
</li></ul>
			</description>
		</method>
    <method name='transformjoin'>
			<arglist><arg name= "source1DataSet" optional='0' type="Unknown Type (input dataset)" /><arg name= "source2DataSet" optional='0' type="Unknown Type (input dataset)" /><arg name= "destDataSet" optional='0' type="symbol" /></arglist>
			<description>
            <p>Apply the query to a source FluidDataSet and join the resulting subset at the end of the items sharing the same identifiers in a second source. Items unique to a source dataset will be ignored. To add items at the end of a dataset instead, see the 'merge' method of FluidDataSet.</p>

        
<h5>Argument details:</h5>        <ul><li>source1DataSet: <p>Source data, or the DataSet name</p>
</li><li>source2DataSet: <p>Source data, or the DataSet name</p>
</li><li>destDataSet: <p>Destination data, or the DataSet name</p>
</li></ul>
			</description>
		</method>
    <method name='addcolumn'>
			<arglist><arg name= "column" optional='0' type="int" /></arglist>
			<description>
            <p>Add a column to the query</p>

        
<h5>Argument details:</h5>        <ul><li>column: <p>Column index</p>
</li></ul>
			</description>
		</method>
    <method name='addrange'>
			<arglist><arg name= "start" optional='0' type="int" /><arg name= "count" optional='0' type="int" /></arglist>
			<description>
            <p>Add a range of columns to the query</p>

        
<h5>Argument details:</h5>        <ul><li>start: <p>First index</p>
</li><li>count: <p>Number of columns</p>
</li></ul>
			</description>
		</method>
    <method name='filter'>
			<arglist><arg name= "column" optional='0' type="int" /><arg name= "condition" optional='0' type="symbol" /><arg name= "value" optional='0' type="float64" /></arglist>
			<description>
            <p>Filter points according to some condition.</p>

        
<h5>Argument details:</h5>        <ul><li>column: <p>Column index</p>
</li><li>condition: <p>Condition string. Possible values: &quot;==&quot;, &quot;!=&quot;, &quot;&lt;&quot;, &quot;&lt;=&quot;, &quot;&gt;&quot;, &quot;&gt;=&quot;</p>
</li><li>value: <p>Condition value</p>
</li></ul>
			</description>
		</method>
    <method name='and'>
			<arglist><arg name= "column" optional='0' type="int" /><arg name= "condition" optional='0' type="symbol" /><arg name= "value" optional='0' type="float64" /></arglist>
			<description>
            <p>Add a condition to an existing filter with an &quot;and&quot; connector.</p>

        
<h5>Argument details:</h5>        <ul><li>column: <p>Column index</p>
</li><li>condition: <p>Condition string. Possible values: &quot;==&quot;, &quot;!=&quot;, &quot;&lt;&quot;, &quot;&lt;=&quot;, &quot;&gt;&quot;, &quot;&gt;=&quot;</p>
</li><li>value: <p>Condition value</p>
</li></ul>
			</description>
		</method>
    <method name='or'>
			<arglist><arg name= "column" optional='0' type="int" /><arg name= "condition" optional='0' type="symbol" /><arg name= "value" optional='0' type="float64" /></arglist>
			<description>
            <p>Add a condition to an existing filter with an &quot;or&quot; connector.</p>

        
<h5>Argument details:</h5>        <ul><li>column: <p>Column index</p>
</li><li>condition: <p>Condition string. Possible values: &quot;==&quot;, &quot;!=&quot;, &quot;&lt;&quot;, &quot;&lt;=&quot;, &quot;&gt;&quot;, &quot;&gt;=&quot;</p>
</li><li>value: <p>Condition value</p>
</li></ul>
			</description>
		</method>
    <method name='clear'>
			<arglist></arglist>
			<description>
            <p>Resets the internal state of the model</p>

        
        <ul></ul>
			</description>
		</method>
    <method name='limit'>
			<arglist><arg name= "points" optional='0' type="int" /></arglist>
			<description>
            <p>Limit the number of resulting points.</p>

        
<h5>Argument details:</h5>        <ul><li>points: <p>Maximum number of points</p>
</li></ul>
			</description>
		</method>
</methodlist>
