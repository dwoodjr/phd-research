# Git LFS Configuration
# Large media files

# Audio files
*.wav filter=lfs diff=lfs merge=lfs -text
*.aif filter=lfs diff=lfs merge=lfs -text
*.aiff filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.flac filter=lfs diff=lfs merge=lfs -text

# Video files
*.mov filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text
*.mkv filter=lfs diff=lfs merge=lfs -text

# TouchDesigner files
*.toe filter=lfs diff=lfs merge=lfs -text
*.tox filter=lfs diff=lfs merge=lfs -text

# Image files (large formats)
*.psd filter=lfs diff=lfs merge=lfs -text
*.tif filter=lfs diff=lfs merge=lfs -text
*.tiff filter=lfs diff=lfs merge=lfs -text

# Archives
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.rar filter=lfs diff=lfs merge=lfs -text

# PDF (compiled dissertation, figures)
*.pdf filter=lfs diff=lfs merge=lfs -text

# Max/MSP compiled externals (patches .maxpat are text JSON - not LFS)
*.mxo filter=lfs diff=lfs merge=lfs -text
*.mxt filter=lfs diff=lfs merge=lfs -text

# Houdini
*.hip filter=lfs diff=lfs merge=lfs -text
*.hiplc filter=lfs diff=lfs merge=lfs -text
*.hda filter=lfs diff=lfs merge=lfs -text

# Unity
*.unitypackage filter=lfs diff=lfs merge=lfs -text
*.unity filter=lfs diff=lfs merge=lfs -text

# Python notebooks
*.ipynb filter=lfs diff=lfs merge=lfs -text

# 3D / point cloud
*.vdb filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
